{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "background": "transparent",
  "config": {
    "font": "Inter, sans-serif",
    "axisLeft": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titleFontWeight": 600,
      "titleColor": "#1561a0",
      "labelColor": "#526070",
      "gridColor": "#e8edf3",
      "gridDash": [3, 3],
      "domainColor": "#cfd9e6",
      "tickColor": "#cfd9e6",
      "labels": false,
      "ticks": false,
      "domain": false
    },
    "axisRight": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titleFontWeight": 600,
      "titleColor": "#b8321f",
      "labelColor": "#b8321f",
      "gridColor": "transparent",
      "domainColor": "#f0c0b8",
      "tickColor": "#f0c0b8",
      "labels": false,
      "ticks": false,
      "domain": false
    },
    "axisBottom": {
      "labelFont": "Inter, sans-serif",
      "labelFontSize": 13,
      "labelFontWeight": 600,
      "labelColor": "#0a1628",
      "domainColor": "#cfd9e6",
      "tickColor": "#cfd9e6",
      "grid": false
    },
    "view": { "stroke": "transparent" }
  },
  "data": {
    "values": [
      {"Month_Num":1,"Month":"Jan","Season":"NE Monsoon","Total_Events":13,"Total_Affected":371802,"Avg_Per_Event":28600},
      {"Month_Num":2,"Month":"Feb","Season":"NE Monsoon","Total_Events":6,"Total_Affected":88854,"Avg_Per_Event":14809},
      {"Month_Num":3,"Month":"Mar","Season":"Transition","Total_Events":2,"Total_Affected":10428,"Avg_Per_Event":5214},
      {"Month_Num":4,"Month":"Apr","Season":"Transition","Total_Events":2,"Total_Affected":2500,"Avg_Per_Event":1250},
      {"Month_Num":5,"Month":"May","Season":"SW Monsoon","Total_Events":1,"Total_Affected":5782,"Avg_Per_Event":5782},
      {"Month_Num":6,"Month":"Jun","Season":"SW Monsoon","Total_Events":3,"Total_Affected":11210,"Avg_Per_Event":3737},
      {"Month_Num":7,"Month":"Jul","Season":"SW Monsoon","Total_Events":3,"Total_Affected":1269,"Avg_Per_Event":423},
      {"Month_Num":8,"Month":"Aug","Season":"SW Monsoon","Total_Events":2,"Total_Affected":14828,"Avg_Per_Event":7414},
      {"Month_Num":9,"Month":"Sep","Season":"Transition","Total_Events":1,"Total_Affected":255,"Avg_Per_Event":255},
      {"Month_Num":10,"Month":"Oct","Season":"Transition","Total_Events":6,"Total_Affected":22812,"Avg_Per_Event":3802},
      {"Month_Num":11,"Month":"Nov","Season":"NE Monsoon","Total_Events":14,"Total_Affected":175263,"Avg_Per_Event":12519},
      {"Month_Num":12,"Month":"Dec","Season":"NE Monsoon","Total_Events":21,"Total_Affected":1309590,"Avg_Per_Event":62361}
    ]
  },
  "resolve": { "scale": { "y": "independent" } },
  "layer": [
    {
      "params": [
        {
          "name": "season_select",
          "select": { "type": "point", "fields": ["Season"] },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "ordinal",
          "sort": ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],
          "axis": { "title": null, "labelAngle": 0 }
        },
        "y": {
          "field": "Total_Affected",
          "type": "quantitative",
          "axis": {
            "title": "Total people displaced (60 years)",
            "titleColor": "#1561a0",
            "titlePadding": 12,
            "grid": true,
            "gridColor": "#e8edf3",
            "gridDash": [3, 3]
          }
        },
        "color": {
          "field": "Season",
          "type": "nominal",
          "scale": {
            "domain": ["NE Monsoon", "SW Monsoon", "Transition"],
            "range": ["#1561a0", "#0f9b8a", "#a87c18"]
          },
          "legend": {
            "title": "Season",
            "orient": "top-left",
            "symbolSize": 120,
            "symbolStrokeWidth": 0,
            "labelFontSize": 12,
            "titleFontSize": 11,
            "titleFontWeight": 600,
            "labelColor": "#0a1628",
            "titleColor": "#526070"
          }
        },
        "opacity": {
          "condition": { "param": "season_select", "value": 1 },
          "value": 0.15
        },
        "tooltip": [
          {"field": "Month",          "type": "nominal",      "title": "Month"},
          {"field": "Season",         "type": "nominal",      "title": "Season"},
          {"field": "Total_Events",   "type": "quantitative", "title": "Total Events"},
          {"field": "Total_Affected", "type": "quantitative", "title": "Total Displaced", "format": ","},
          {"field": "Avg_Per_Event",  "type": "quantitative", "title": "Avg Displaced / Event", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#b8321f",
        "strokeWidth": 2.5,
        "interpolate": "monotone",
        "point": false
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "ordinal",
          "sort": ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
        },
        "y": {
          "field": "Total_Events",
          "type": "quantitative",
          "axis": {
            "title": "Number of flood events",
            "titleColor": "#b8321f",
            "titlePadding": 12
          }
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "color": "#b8321f",
        "filled": true,
        "size": 55,
        "strokeWidth": 1.5,
        "stroke": "#ffffff"
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "ordinal",
          "sort": ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
        },
        "y": {
          "field": "Total_Events",
          "type": "quantitative"
        },
        "tooltip": [
          {"field": "Month",          "type": "nominal",      "title": "Month"},
          {"field": "Total_Events",   "type": "quantitative", "title": "Total Events"},
          {"field": "Total_Affected", "type": "quantitative", "title": "Total Displaced", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -14,
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#b8321f"
      },
      "transform": [
        { "filter": "datum.Total_Events >= 13" }
      ],
      "encoding": {
        "x": {
          "field": "Month",
          "type": "ordinal",
          "sort": ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
        },
        "y": {
          "field": "Total_Events",
          "type": "quantitative"
        },
        "text": { "field": "Total_Events", "type": "quantitative" }
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -10,
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#1561a0"
      },
      "transform": [
        { "filter": "datum.Total_Affected >= 300000" }
      ],
      "encoding": {
        "x": {
          "field": "Month",
          "type": "ordinal",
          "sort": ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
        },
        "y": {
          "field": "Total_Affected",
          "type": "quantitative"
        },
        "text": {
          "condition": {
            "test": "datum.Total_Affected >= 1000000",
            "value": "1.3M displaced"
          },
          "value": ""
        }
      }
    }
  ]
}