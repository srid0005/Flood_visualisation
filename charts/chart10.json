{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total Flood Deaths by Decade (1960s\u20132020s)",
    "subtitle": "Red lollipops exceed 90 deaths. Hover any decade for full details.",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "font": "Inter, sans-serif",
    "subtitleFont": "Inter, sans-serif",
    "color": "#0a1628",
    "subtitleColor": "#526070"
  },
  "width": "container",
  "height": 380,
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "grid": false,
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "mark": {
      "cursor": "pointer"
    }
  },
  "data": {
    "url": "data/deaths_decade.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#eaeff5",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "datum": 20
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#eaeff5",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "datum": 40
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#eaeff5",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "datum": 60
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#eaeff5",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "datum": 80
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#eaeff5",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "datum": 100
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#cfd9e6",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "datum": 0
        }
      }
    },
    {
      "mark": {
        "type": "bar",
        "width": 32,
        "opacity": 0,
        "cursor": "pointer",
        "tooltip": true
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "ordinal",
          "sort": [
            "1960s",
            "1970s",
            "1980s",
            "1990s",
            "2000s",
            "2010s",
            "2020s"
          ]
        },
        "y": {
          "datum": 120
        },
        "y2": {
          "datum": 0
        },
        "tooltip": [
          {
            "field": "Decade",
            "type": "ordinal",
            "title": "Decade"
          },
          {
            "field": "Total_Deaths",
            "type": "quantitative",
            "title": "Total Deaths"
          },
          {
            "field": "Total_Events",
            "type": "quantitative",
            "title": "Events that Decade"
          },
          {
            "field": "Worst_Year",
            "type": "ordinal",
            "title": "Worst Single Year"
          },
          {
            "field": "Worst_Deaths",
            "type": "quantitative",
            "title": "Deaths in Worst Year"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 4
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "ordinal",
          "sort": [
            "1960s",
            "1970s",
            "1980s",
            "1990s",
            "2000s",
            "2010s",
            "2020s"
          ],
          "axis": {
            "title": "Decade",
            "labelAngle": 0,
            "labelFontSize": 12,
            "labelFontWeight": "bold",
            "domainColor": "#cfd9e6",
            "domainWidth": 1.5,
            "tickColor": "#cfd9e6"
          }
        },
        "y": {
          "field": "Total_Deaths",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              120
            ]
          },
          "axis": {
            "title": "Total Deaths",
            "tickCount": 7,
            "domainColor": "#cfd9e6",
            "domainWidth": 1.5,
            "tickColor": "#cfd9e6"
          }
        },
        "y2": {
          "datum": 0
        },
        "color": {
          "condition": {
            "test": "datum.Total_Deaths > 90",
            "value": "#c0392b"
          },
          "value": "#2e86c1"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 120,
        "stroke": "#0a1628",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "ordinal",
          "sort": [
            "1960s",
            "1970s",
            "1980s",
            "1990s",
            "2000s",
            "2010s",
            "2020s"
          ]
        },
        "y": {
          "field": "Total_Deaths",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              120
            ]
          }
        },
        "color": {
          "condition": {
            "test": "datum.Total_Deaths > 90",
            "value": "#c0392b"
          },
          "value": "#2e86c1"
        },
        "tooltip": [
          {
            "field": "Decade",
            "type": "ordinal",
            "title": "Decade"
          },
          {
            "field": "Total_Deaths",
            "type": "quantitative",
            "title": "Total Deaths"
          },
          {
            "field": "Total_Events",
            "type": "quantitative",
            "title": "Events that Decade"
          },
          {
            "field": "Worst_Year",
            "type": "ordinal",
            "title": "Worst Single Year"
          },
          {
            "field": "Worst_Deaths",
            "type": "quantitative",
            "title": "Deaths in Worst Year"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -16,
        "fontSize": 11,
        "fontWeight": 700,
        "font": "Inter, sans-serif"
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "ordinal",
          "sort": [
            "1960s",
            "1970s",
            "1980s",
            "1990s",
            "2000s",
            "2010s",
            "2020s"
          ]
        },
        "y": {
          "field": "Total_Deaths",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              120
            ]
          }
        },
        "text": {
          "field": "Total_Deaths",
          "type": "quantitative"
        },
        "color": {
          "condition": {
            "test": "datum.Total_Deaths > 90",
            "value": "#c0392b"
          },
          "value": "#0a1628"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Decade == '2020s'"
        }
      ],
      "mark": {
        "type": "text",
        "dy": -32,
        "fontSize": 9.5,
        "fontWeight": 600,
        "fontStyle": "italic",
        "font": "Inter, sans-serif",
        "color": "#c0392b",
        "align": "center"
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "ordinal",
          "sort": [
            "1960s",
            "1970s",
            "1980s",
            "1990s",
            "2000s",
            "2010s",
            "2020s"
          ]
        },
        "y": {
          "field": "Total_Deaths",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              120
            ]
          }
        },
        "text": {
          "value": "Worst decade yet"
        }
      }
    }
  ]
}