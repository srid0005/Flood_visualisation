      {"State":"Kelantan",       "Era":"2000–2014","Total_Affected":400000,"LabelY_L":415000,"LabelY_R":265000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Terengganu",     "Era":"2000–2014","Total_Affected":380000,"LabelY_L":375000,"LabelY_R":280000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Perak",          "Era":"2000–2014","Total_Affected":253000,"LabelY_L":258000,"LabelY_R":232000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Selangor",       "Era":"2000–2014","Total_Affected":220000,"LabelY_L":218000,"LabelY_R":196000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Negeri Sembilan","Era":"2000–2014","Total_Affected":100000,"LabelY_L":92000, "LabelY_R":118000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Melaka",         "Era":"2000–2014","Total_Affected":130000,"LabelY_L":135000,"LabelY_R":108000,"Key":false,"Rising":false,"Group":"other"},

      {"State":"Pahang",         "Era":"2015–2024","Total_Affected":290049,"LabelY_L":640000,"LabelY_R":310000,"Key":true, "Rising":false,"Group":"key"},
      {"State":"Johor",          "Era":"2015–2024","Total_Affected":273031,"LabelY_L":590000,"LabelY_R":255000,"Key":true, "Rising":false,"Group":"key"},
      {"State":"Sabah",          "Era":"2015–2024","Total_Affected":325364,"LabelY_L":105000,"LabelY_R":338000,"Key":true, "Rising":true, "Group":"key"},
      {"State":"Perlis",         "Era":"2015–2024","Total_Affected":262412,"LabelY_L":45000, "LabelY_R":272000,"Key":true, "Rising":true, "Group":"key"},
      {"State":"Kelantan",       "Era":"2015–2024","Total_Affected":250813,"LabelY_L":415000,"LabelY_R":265000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Terengganu",     "Era":"2015–2024","Total_Affected":268106,"LabelY_L":375000,"LabelY_R":280000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Perak",          "Era":"2015–2024","Total_Affected":240869,"LabelY_L":258000,"LabelY_R":232000,"Key":false,"Rising":false,"Group":"other"},
      {"State":"Selangor",       "Era":"2015–2024","Total_Affected":190776,"LabelY_L":218000,"LabelY_R":196000,"Key":false,"Rising":false,"Group":"other"},
