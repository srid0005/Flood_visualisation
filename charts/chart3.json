{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Which States Bore the Greatest Flood Burden — and Did It Change?",
    "subtitle": "Bold lines = key states. Dashed = average of all other states. Grey band = range.",
    "anchor": "start", "fontSize": 14, "subtitleFontSize": 11,
    "font": "DM Sans", "subtitleFont": "DM Sans",
    "color": "#0d1b2a", "subtitleColor": "#6a8090"
  },
  "width": "container",
  "height": 600,
  "padding": {"left": 140, "right": 160},
  "config": {
    "view": {"stroke": "transparent"},
    "axis": {
      "grid": true, "gridColor": "#f0f4f8", "gridWidth": 1,
      "domain": false, "ticks": false,
      "labelFont": "DM Sans", "titleFont": "DM Sans",
      "labelFontSize": 12, "titleFontSize": 12
    },
    "legend": {"disable": true}
  },
  "data": {
    "values": [
      {"State":"Pahang",         "Era":"2000–2014","Total_Affected":614239,"LabelY_L":640000,"LabelY_R":310000,"Key":true, "Rising":false,"Group":"key"},
      {"State":"Johor",          "Era":"2000–2014","Total_Affected":601783,"LabelY_L":590000,"LabelY_R":255000,"Key":true, "Rising":false,"Group":"key"},
