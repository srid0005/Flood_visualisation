  },
  "params": [
    {
      "name": "sel_state",
      "value": "All States",
      "bind": {
        "input": "select",
        "options": ["All States","Pahang","Johor","Sabah","Perlis","Kelantan","Terengganu","Perak","Selangor","Melaka","Negeri Sembilan"],
        "name": "Highlight state: "
      }
    }
  ],
  "layer": [
    {
      "transform": [
        {"filter": "datum.Group == 'other'"}
      ],
      "mark": {"type": "line", "interpolate": "linear", "strokeCap": "round", "strokeDash": [6, 4], "strokeWidth": 2, "color": "#b0b8c4", "opacity": 0.5},
      "encoding": {
        "x": {
          "field": "Era", "type": "ordinal",
          "sort": ["2000–2014","2015–2024"],
          "axis": {
            "title": "", "labelAngle": 0,
            "labelFontSize": 13, "labelFontWeight": "bold",
            "labelPadding": 12, "orient": "top"
          }
        },
        "y": {
          "aggregate": "mean", "field": "Total_Affected", "type": "quantitative",
          "scale": {"domain": [0, 680000]},
          "axis": {"title": "Total People Displaced", "format": "~s", "tickCount": 7}
        }
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'other'"}
      ],
      "mark": {"type": "line", "interpolate": "linear", "strokeCap": "round", "strokeDash": [6, 4], "strokeWidth": 1.5, "color": "#8090a4", "opacity": 0.25},
      "encoding": {
        "x": {
          "field": "Era", "type": "ordinal",
          "sort": ["2000–2014","2015–2024"]
        },
        "y": {
          "field": "Total_Affected", "type": "quantitative",
          "scale": {"domain": [0, 680000]}
        },
        "detail": {"field": "State"}
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'key'"}
      ],
      "mark": {"type": "line", "interpolate": "linear", "strokeCap": "round"},
      "encoding": {
        "x": {
          "field": "Era", "type": "ordinal",
          "sort": ["2000–2014","2015–2024"]
        },
        "y": {
          "field": "Total_Affected", "type": "quantitative",
          "scale": {"domain": [0, 680000]}
        },
        "detail": {"field": "State"},
        "color": {
          "condition": [
            {"test": "datum.State == 'Pahang'", "value": "#0077BB"},
            {"test": "datum.State == 'Johor'",  "value": "#EE7733"},
            {"test": "datum.State == 'Sabah'",  "value": "#EE3377"},
            {"test": "datum.State == 'Perlis'", "value": "#CCBB44"}
          ],
          "value": "#ccc"
        },
        "strokeWidth": {
          "condition": {"test": "sel_state == 'All States' || datum.State == sel_state", "value": 3.5},
          "value": 0.5
        },
        "opacity": {
          "condition": {"test": "sel_state == 'All States' || datum.State == sel_state", "value": 1},
          "value": 0.06
        }
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'key'"}
      ],
      "mark": {"type": "circle", "stroke": "white", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "Total_Affected", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "color": {
          "condition": [
            {"test": "datum.State == 'Pahang'", "value": "#0077BB"},
            {"test": "datum.State == 'Johor'",  "value": "#EE7733"},
            {"test": "datum.State == 'Sabah'",  "value": "#EE3377"},
            {"test": "datum.State == 'Perlis'", "value": "#CCBB44"}
          ],
          "value": "#ccc"
        },
        "size": {
          "condition": {"test": "sel_state == 'All States' || datum.State == sel_state", "value": 110},
          "value": 30
        },
        "opacity": {
          "condition": {"test": "sel_state == 'All States' || datum.State == sel_state", "value": 0.95},
          "value": 0.06
        },
        "tooltip": [
          {"field": "State", "type": "nominal", "title": "State"},
          {"field": "Era", "type": "ordinal", "title": "Era"},
          {"field": "Total_Affected", "type": "quantitative", "title": "Displaced", "format": ","}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'other'"},
        {"filter": "datum.Era == '2000–2014'"}
      ],
      "mark": {"type": "circle", "stroke": "white", "strokeWidth": 1.5, "opacity": 0.3},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "Total_Affected", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "color": {"value": "#b0b8c4"},
        "size": {"value": 35}
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'other'"},
        {"filter": "datum.Era == '2015–2024'"}
      ],
      "mark": {"type": "circle", "stroke": "white", "strokeWidth": 1.5, "opacity": 0.3},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "Total_Affected", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "color": {"value": "#b0b8c4"},
        "size": {"value": 35}
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'other'"},
        {"aggregate": [{"op": "mean", "field": "Total_Affected", "as": "avg"}], "groupby": ["Era"]},
        {"filter": "datum.Era == '2000–2014'"}
      ],
      "mark": {"type": "text", "align": "right", "dx": -14, "font": "DM Sans", "fontStyle": "italic", "fontSize": 10, "fontWeight": 400},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "avg", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "text": {"value": "Avg others"},
        "color": {"value": "#8090a4"}
      }
    },
    {
      "transform": [
        {"filter": "datum.Group == 'other'"},
        {"aggregate": [{"op": "mean", "field": "Total_Affected", "as": "avg"}], "groupby": ["Era"]},
        {"filter": "datum.Era == '2015–2024'"}
      ],
      "mark": {"type": "text", "align": "left", "dx": 14, "font": "DM Sans", "fontStyle": "italic", "fontSize": 10, "fontWeight": 400},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "avg", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "text": {"value": "Avg others"},
        "color": {"value": "#8090a4"}
      }
    },
    {
      "transform": [
        {"filter": "datum.Era == '2000–2014'"},
        {"filter": "datum.Group == 'key'"},
        {"filter": "sel_state == 'All States' || datum.State == sel_state"}
      ],
      "mark": {"type": "text", "align": "right", "dx": -14, "font": "DM Sans"},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "LabelY_L", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "text": {"field": "State", "type": "nominal"},
        "fontSize": {"value": 11.5},
        "fontWeight": {"value": 700},
        "color": {
          "condition": [
            {"test": "datum.State == 'Pahang'", "value": "#0055aa"},
            {"test": "datum.State == 'Johor'",  "value": "#cc5500"},
            {"test": "datum.State == 'Sabah'",  "value": "#cc1155"},
            {"test": "datum.State == 'Perlis'", "value": "#998800"}
          ],
          "value": "#999"
        }
      }
    },
    {
      "transform": [
        {"filter": "datum.Era == '2015–2024'"},
        {"filter": "datum.Group == 'key'"},
        {"filter": "sel_state == 'All States' || datum.State == sel_state"}
      ],
      "mark": {"type": "text", "align": "left", "dx": 14, "font": "DM Sans"},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "LabelY_R", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "text": {
          "condition": {"test": "datum.Rising", "field": "State", "type": "nominal"},
          "field": "State", "type": "nominal"
        },
        "fontSize": {"value": 11.5},
        "fontWeight": {"value": 700},
        "color": {
          "condition": [
            {"test": "datum.State == 'Pahang'", "value": "#0055aa"},
            {"test": "datum.State == 'Johor'",  "value": "#cc5500"},
            {"test": "datum.State == 'Sabah'",  "value": "#cc1155"},
            {"test": "datum.State == 'Perlis'", "value": "#998800"}
          ],
          "value": "#999"
        }
      }
    },
    {
      "transform": [
        {"filter": "datum.Era == '2015–2024' && datum.Rising && datum.Group == 'key'"},
        {"filter": "sel_state == 'All States' || datum.State == sel_state"}
      ],
      "mark": {"type": "text", "align": "left", "dx": 14, "font": "DM Sans", "fontStyle": "italic", "fontSize": 9, "dy": 13},
      "encoding": {
        "x": {"field": "Era", "type": "ordinal", "sort": ["2000–2014","2015–2024"]},
        "y": {"field": "LabelY_R", "type": "quantitative", "scale": {"domain": [0, 680000]}},
        "text": {"value": "↑ Rising"},
        "color": {"value": "#e74c3c"}
      }
    }
  ]
}