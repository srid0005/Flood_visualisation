{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Flood Event Frequency by State",
    "subtitle": "Darker blue = more flood events since 1965. Hover for state details.",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "font": "Inter, sans-serif",
    "subtitleFont": "Inter, sans-serif",
    "color": "#0a1628",
    "subtitleColor": "#526070"
  },
  "width": "container",
  "height": 460,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "legend": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelFontSize": 11
    }
  },
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "data/malaysia_states.topojson",
    "format": {
      "type": "topojson",
      "feature": "layer"
    }
  },
  "transform": [
    {
      "lookup": "properties.NAME_1",
      "from": {
        "data": {
          "url": "data/state_freq_map.csv"
        },
        "key": "State",
        "fields": ["Event_Count", "Total_Affected"]
      },
      "default": {
        "Event_Count": 0,
        "Total_Affected": 0
      }
    },
    {
      "calculate": "toNumber(datum.Event_Count)",
      "as": "Events"
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1.5
  },
  "encoding": {
    "color": {
      "field": "Events",
      "type": "quantitative",
      "scale": {
        "scheme": "blues",
        "domain": [0, 20]
      },
      "title": "Flood Events",
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 300,
        "gradientThickness": 12,
        "titleAnchor": "middle",
        "titleOrient": "left",
        "labelOverlap": true
      }
    },
    "tooltip": [
      {
        "field": "properties.NAME_1",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "Events",
        "type": "quantitative",
        "title": "Flood Events"
      },
      {
        "field": "Total_Affected",
        "type": "quantitative",
        "title": "Total Displaced",
        "format": ","
      }
    ]
  }
}