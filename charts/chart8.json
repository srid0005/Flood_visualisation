{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total Displacement by State \u2014 Proportional Symbol Map",
    "subtitle": "Circle size = total displaced. Orange intensity = avg severity per event. Hover for details.",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "font": "Inter, sans-serif",
    "subtitleFont": "Inter, sans-serif",
    "color": "#0a1628",
    "subtitleColor": "#526070"
  },
  "width": "container",
  "height": 440,
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "legend": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelFontSize": 11
    }
  },
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "data": {
        "url": "data/malaysia-states-simplified.json",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#d4e8f5",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "tooltip": [
          {
            "field": "properties.shapeName",
            "type": "nominal",
            "title": "State"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/state_centroids_full.csv"
      },
      "transform": [
        {
          "filter": "datum.Event_Count > 0"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.82,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "longitude": {
          "field": "Longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "Latitude",
          "type": "quantitative"
        },
        "size": {
          "field": "Total_Affected",
          "type": "quantitative",
          "scale": {
            "range": [
              60,
              2500
            ]
          },
          "title": "Total Displaced",
          "legend": {
            "orient": "bottom-right",
            "symbolFillColor": "#1561a0",
            "values": [
              100000,
              300000,
              600000,
              900000
            ]
          }
        },
        "color": {
          "field": "Avg_Affected_per_Event",
          "type": "quantitative",
          "scale": {
            "scheme": "oranges",
            "domain": [
              0,
              90000
            ]
          },
          "title": "Avg Displaced / Event",
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 130
          }
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Event_Count",
            "type": "quantitative",
            "title": "Events"
          },
          {
            "field": "Total_Affected",
            "type": "quantitative",
            "title": "Total Displaced",
            "format": ","
          },
          {
            "field": "Avg_Affected_per_Event",
            "type": "quantitative",
            "title": "Avg per Event",
            "format": ","
          }
        ]
      }
    }
  ]
}