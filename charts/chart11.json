{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Displacement vs. Deaths by Decade — The Decoupling Story",
    "subtitle": "Each panel = one decade. X = people displaced. Y = deaths. Drag slider to highlight deadly years.",
    "anchor": "start", "fontSize": 14, "subtitleFontSize": 11,
    "font": "Inter, sans-serif", "subtitleFont": "Inter, sans-serif",
    "color": "#0a1628", "subtitleColor": "#526070"
  },
  "config": {
    "view": {"stroke": "#e8edf3", "strokeWidth": 1},
    "axis": {
      "grid": true, "gridColor": "#f0f4f8", "gridWidth": 1,
      "domain": true, "domainColor": "#cfd9e6", "domainWidth": 1.2,
      "ticks": true, "tickColor": "#cfd9e6",
      "labelFont": "Inter, sans-serif", "titleFont": "Inter, sans-serif",
      "labelFontSize": 9, "titleFontSize": 10
    },
    "header": {
      "labelFont": "Inter, sans-serif", "labelFontSize": 12,
      "labelFontWeight": 700, "labelColor": "#0a1628",
      "titleFont": "Inter, sans-serif"
    },
    "legend": {
      "labelFont": "Inter, sans-serif", "titleFont": "Inter, sans-serif",
      "labelFontSize": 11
    },
    "facet": {"spacing": 12}
  },
  "data": {
    "values": [
      {"Year":1965,"Total_Deaths":6, "Total_Affected":300000,"Decade":"1960s"},
      {"Year":1967,"Total_Deaths":50,"Total_Affected":140000,"Decade":"1960s"},
