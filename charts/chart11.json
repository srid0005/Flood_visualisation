      {"Year":1987,"Total_Deaths":3, "Total_Affected":2576,  "Decade":"1980s"},
      {"Year":1988,"Total_Deaths":27,"Total_Affected":60000, "Decade":"1980s"},
      {"Year":1993,"Total_Deaths":30,"Total_Affected":25000, "Decade":"1990s"},
      {"Year":1996,"Total_Deaths":0, "Total_Affected":418,   "Decade":"1990s"},
      {"Year":1998,"Total_Deaths":0, "Total_Affected":2500,  "Decade":"1990s"},
      {"Year":1999,"Total_Deaths":1, "Total_Affected":2000,  "Decade":"1990s"},
      {"Year":2000,"Total_Deaths":12,"Total_Affected":8000,  "Decade":"2000s"},
      {"Year":2001,"Total_Deaths":11,"Total_Affected":33200, "Decade":"2000s"},
      {"Year":2003,"Total_Deaths":8, "Total_Affected":18800, "Decade":"2000s"},
      {"Year":2004,"Total_Deaths":16,"Total_Affected":31038, "Decade":"2000s"},
      {"Year":2005,"Total_Deaths":13,"Total_Affected":30600, "Decade":"2000s"},
      {"Year":2006,"Total_Deaths":6, "Total_Affected":106518,"Decade":"2000s"},
      {"Year":2007,"Total_Deaths":46,"Total_Affected":166533,"Decade":"2000s"},
      {"Year":2008,"Total_Deaths":0, "Total_Affected":8000,  "Decade":"2000s"},
      {"Year":2009,"Total_Deaths":0, "Total_Affected":10875, "Decade":"2000s"},
      {"Year":2011,"Total_Deaths":2, "Total_Affected":20000, "Decade":"2010s"},
      {"Year":2013,"Total_Deaths":4, "Total_Affected":75000, "Decade":"2010s"},
      {"Year":2014,"Total_Deaths":17,"Total_Affected":230000,"Decade":"2010s"},
      {"Year":2015,"Total_Deaths":1, "Total_Affected":3000,  "Decade":"2010s"},
      {"Year":2016,"Total_Deaths":0, "Total_Affected":31841, "Decade":"2010s"},
      {"Year":2017,"Total_Deaths":9, "Total_Affected":21981, "Decade":"2010s"},
      {"Year":2018,"Total_Deaths":2, "Total_Affected":16900, "Decade":"2010s"},
      {"Year":2019,"Total_Deaths":2, "Total_Affected":22477, "Decade":"2010s"},
      {"Year":2020,"Total_Deaths":0, "Total_Affected":21883, "Decade":"2020s"},
      {"Year":2021,"Total_Deaths":79,"Total_Affected":164641,"Decade":"2020s"},
      {"Year":2022,"Total_Deaths":17,"Total_Affected":90625, "Decade":"2020s"},
