  },
  "params": [
    {
      "name": "ch11_threshold",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0, "max": 60, "step": 5,
        "name": "Highlight years with deaths ≥ "
      }
    }
  ],
  "facet": {
    "field": "Decade", "type": "ordinal",
    "sort": ["1960s","1970s","1980s","1990s","2000s","2010s","2020s"],
    "header": {"title": null, "labelOrient": "top"}
  },
  "columns": 4,
  "spec": {
    "width": 155,
    "height": 155,
    "layer": [
      {
        "mark": {
          "type": "circle",
          "stroke": "#0a1628",
          "strokeWidth": 1.1
        },
        "encoding": {
          "x": {
            "field": "Total_Affected", "type": "quantitative",
            "axis": {"title": "Displaced", "format": "~s", "tickCount": 3},
            "scale": {"zero": true}
          },
          "y": {
            "field": "Total_Deaths", "type": "quantitative",
            "axis": {"title": "Deaths", "tickCount": 4},
            "scale": {"zero": true}
          },
          "size": {"value": 120},
          "color": {
            "condition": {
              "test": "datum.Total_Deaths >= ch11_threshold && ch11_threshold > 0",
              "value": "#c0392b"
            },
            "field": "Decade", "type": "nominal",
            "scale": {
              "domain": ["1960s","1970s","1980s","1990s","2000s","2010s","2020s"],
              "range": ["#4e79a7","#f28e2b","#e15759","#76b7b2","#59a14f","#edc948","#b07aa1"]
            },
            "legend": null
          },
          "opacity": {
            "condition": {
              "test": "ch11_threshold == 0 || datum.Total_Deaths >= ch11_threshold",
              "value": 0.88
            },
            "value": 0.12
          },
          "tooltip": [
            {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
            {"field": "Total_Deaths", "type": "quantitative", "title": "Deaths"},
            {"field": "Total_Affected", "type": "quantitative", "title": "Displaced", "format": ","}
          ]
        }
      },
      {
        "transform": [
          {"filter": "datum.Total_Deaths >= ch11_threshold && ch11_threshold > 0"}
        ],
        "mark": {
          "type": "text",
          "fontSize": 8.5,
          "fontWeight": 700,
          "font": "Inter, sans-serif",
          "dy": -10,
          "color": "#c0392b"
        },
        "encoding": {
          "x": {"field": "Total_Affected", "type": "quantitative"},
          "y": {"field": "Total_Deaths", "type": "quantitative"},
          "text": {"field": "Year", "type": "quantitative", "format": "d"}
        }
      }
    ]
  }
}